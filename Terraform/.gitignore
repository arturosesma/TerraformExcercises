# Terraform state and lock files — never commit
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Variable files that contain secrets
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Generated plan files
*.tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# macOS
.DS_Store
